# API
API_ENV=development                         # development | staging | production

# Model
MODEL_PATH=models/model.pkl          # local path (dev) or s3://predmaint-ml-platform/models/model.pkl (prod)

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=predmaint
MLFLOW_MODEL_NAME=predmaint-classifier

# Streamlit dashboard
STREAMLIT_API_URL=http://localhost:8000

# Monitoring & drift detection
DRIFT_THRESHOLD=0.05
RETRAINING_TRIGGER=true                     # enable automatic retraining on drift

# Prefect (optional — only needed for Prefect Cloud; local server works without these)
# PREFECT_API_URL=https://api.prefect.cloud/api/accounts/<id>/workspaces/<id>
# PREFECT_API_KEY=
