# API
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development                         # development | staging | production

# Model
MODEL_PATH=models/model.pkl
MODEL_VERSION=latest

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=predmaint
MLFLOW_MODEL_NAME=predmaint-classifier

# Prefect
PREFECT_API_URL=http://localhost:4200/api   # or Prefect Cloud URL
PREFECT_API_KEY=                            # only for Prefect Cloud

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
ECR_REPOSITORY=predmaint-ml-platform
ECS_CLUSTER=predmaint-cluster
ECS_SERVICE=predmaint-api

# S3 (artifacts & data)
S3_BUCKET=
S3_RAW_DATA_PREFIX=data/raw/
S3_PROCESSED_DATA_PREFIX=data/processed/
S3_MODEL_PREFIX=models/

# Streamlit dashboard
STREAMLIT_API_URL=http://localhost:8000

# Monitoring & drift detection
DRIFT_THRESHOLD=0.05
RETRAINING_TRIGGER=true                     # enable automatic retraining on drift
