{
	"family": "predmaint-api",
	"networkMode": "awsvpc",
	"requiresCompatibilities": ["FARGATE"],
	"cpu": "256",
	"memory": "512",
	"executionRoleArn": "arn:aws:iam::321305251356:role/ecsTaskExecutionRole",
	"taskRoleArn": "arn:aws:iam::321305251356:role/ecsTaskRole",
	"containerDefinitions": [
		{
			"name": "predmaint-api",
			"image": "321305251356.dkr.ecr.us-east-2.amazonaws.com/predmaint-api:latest",
			"portMappings": [
				{
					"containerPort": 8000,
					"protocol": "tcp"
				}
			],
			"essential": true,

			"healthCheck": {
				"command": [
					"CMD-SHELL",
					"python -c \"import urllib.request; urllib.request.urlopen('http://localhost:8000/health')\" || exit 1"
				],
				"interval": 30,
				"timeout": 10,
				"retries": 3,
				"startPeriod": 60
			},

			"environment": [
				{ "name": "API_ENV", "value": "production" },
				{ "name": "API_PORT", "value": "8000" },
				{ "name": "AWS_DEFAULT_REGION", "value": "us-east-2" },
				{ "name": "MODEL_PATH", "value": "s3://predmaint-ml-platform/models/model.pkl" }
			],

			"readonlyRootFilesystem": false,
			"privileged": false,

			"ulimits": [
				{
					"name": "nofile",
					"softLimit": 65536,
					"hardLimit": 65536
				}
			],

			"logConfiguration": {
				"logDriver": "awslogs",
				"options": {
					"awslogs-group": "/ecs/predmaint-api",
					"awslogs-region": "us-east-2",
					"awslogs-stream-prefix": "ecs",
					"awslogs-create-group": "true"
				}
			}
		}
	]
}
