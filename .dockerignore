# Exclude version control and tooling
.git/
.github/
.venv/
.ruff_cache/
.mypy_cache/
__pycache__/
*.pyc
*.egg-info/

# Exclude runtime artifacts
mlruns/
mlflow.db
reports/

# Exclude data (large files, not needed at runtime)
data/

# models/ is intentionally NOT excluded so `COPY models/ ./models/` works.
# Place model.pkl in models/ before running `docker build`, or mount it
# at runtime: docker run -v ./models:/app/models predmaint-api
